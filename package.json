{
  "name": "@easysimplecool/design-system",
  "version": "0.2.39",
  "description": "A basic design system package for use in production apps and Figma Make.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/EasySimpleCool/npm-test.git"
  },
  "scripts": {
    "build": "npm run build:tokens && npm run validate:tokens && vite build",
    "build:tokens": "style-dictionary build --config style-dictionary.config.js",
    "validate:tokens": "node scripts/validate-tokens.mjs",
    "dev": "npm run build:tokens && vite build --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@fontsource/inter": "^5.3.0",
    "@fontsource/kablammo": "^5.3.0",
    "@fontsource/montserrat": "^5.3.0",
    "@fontsource/space-grotesk": "^5.3.0",
    "@tokens-studio/sd-transforms": "^1.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "style-dictionary": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0"
  },
  "dependencies": {
    "@fontsource/space-mono": "^5.3.0"
  }
}
